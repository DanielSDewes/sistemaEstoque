# Root env consumed by docker-compose. Copy to `.env` and adjust for your setup.

# --- Postgres ---
POSTGRES_USER=estoque
POSTGRES_PASSWORD=estoque
POSTGRES_DB=estoque

# --- Backend ---
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOW_NEGATIVE_STOCK=false

# Bootstrap admin (created on first start)
FIRST_ADMIN_EMAIL=admin@estoque.com
FIRST_ADMIN_PASSWORD=Admin@123

# Set to true ONLY to load demo data (categories, products, customers, orders).
# Keep false for production.
SEED_SAMPLE_DATA=false
