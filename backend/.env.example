# --- Application ---
PROJECT_NAME=Sistema de Gestao de Estoque
ENVIRONMENT=development
DEBUG=true

# --- Security (CHANGE IN PRODUCTION) ---
SECRET_KEY=change-me-to-a-long-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- Database ---
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=estoque
POSTGRES_PASSWORD=estoque
POSTGRES_DB=estoque
# Optional full override (takes precedence over the POSTGRES_* vars above):
# DATABASE_URL=postgresql+psycopg2://estoque:estoque@db:5432/estoque

# --- CORS (comma-separated) ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Business rules ---
ALLOW_NEGATIVE_STOCK=false
EXPIRY_ALERT_DAYS=30

# --- Auth hardening ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
PASSWORD_MIN_LENGTH=8
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# --- Reverse proxy / client IP ---
# Set TRUST_PROXY_HEADERS=true ONLY when behind a proxy that sets X-Forwarded-For
# (e.g. nginx). TRUSTED_PROXY_HOPS = number of trusted proxies in front of the app.
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_HOPS=1

# --- Rate limiting backend ---
# When set, the login/forgot-password limiter is shared across workers/instances.
# REDIS_URL=redis://localhost:6379/0

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# --- Observability ---
ENABLE_METRICS=true
# When set, /metrics requires this token (Bearer header or ?token=). In
# production with no token set, /metrics is hidden (404).
# METRICS_TOKEN=
# SENTRY_DSN=
# WEB_CONCURRENCY=4

# --- Password reset e-mail (optional; links are logged if SMTP is unset) ---
FRONTEND_BASE_URL=http://localhost:5173
# SMTP_HOST=
SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM=no-reply@estoque.local
SMTP_TLS=true

# --- Bootstrap admin ---
FIRST_ADMIN_EMAIL=admin@estoque.com
FIRST_ADMIN_PASSWORD=Admin@123
FIRST_ADMIN_NAME=Administrador
